# Velvet Haven Resort - Environment Configuration Template
# Copy these keys into your Vercel Project Settings -> Environment Variables

# WhatsApp contact phone number (format: country code without plus sign, e.g. 919846000000)
VITE_WHATSAPP_NUMBER=919846000000

# WhatsApp display format for UI text
VITE_WHATSAPP_DISPLAY_NUMBER=+91 98460 00000

# Primary contact phone number for call links
VITE_CONTACT_PHONE=+91 98460 00000

# Alternative contact phone number
VITE_CONTACT_PHONE_ALT=+91 98460 00001

# Primary resort email address
VITE_EMAIL=velvethavenresort@gmail.com

# Production Website Canonical Base URL
VITE_SITE_URL=https://velvethavenresort.com

# Google Maps link for directions
VITE_MAP_URL=https://maps.app.goo.gl/8vNvgiym9pJrfnoMA
